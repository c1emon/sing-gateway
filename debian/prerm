#!/bin/sh
set -e

STATE_FILE=${SING_GATEWAY_STATE_FILE:-/var/lib/sing-gateway/enabled}

case "$1" in
    remove|deconfigure)
        if [ -f "$STATE_FILE" ] && command -v sing-gateway >/dev/null 2>&1; then
            sing-gateway disable >/dev/null 2>&1 || true
        fi
        ;;
    upgrade|failed-upgrade)
        # Preserve the active drop-in and managed gateway state during upgrade.
        ;;
esac

#DEBHELPER#

exit 0
