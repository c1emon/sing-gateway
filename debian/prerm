#!/bin/sh
set -e

case "$1" in
    remove|deconfigure)
        if command -v sing-gateway >/dev/null 2>&1; then
            sing-gateway disable >/dev/null 2>&1 || true
        else
            rm -f /etc/systemd/system/sing-box.service.d/10-sing-gateway.conf
            if command -v systemctl >/dev/null 2>&1; then
                systemctl daemon-reload >/dev/null 2>&1 || true
            fi
        fi
        ;;
    upgrade|failed-upgrade)
        # Preserve the active drop-in and managed gateway state during upgrade.
        ;;
esac

#DEBHELPER#

exit 0
